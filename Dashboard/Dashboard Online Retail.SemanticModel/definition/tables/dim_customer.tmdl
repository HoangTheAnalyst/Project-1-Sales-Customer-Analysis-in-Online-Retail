			defaultHierarchy: LocalDateTable_65161598-3c73-4142-a7be-fb87bae7e947.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column Customer_First_Purchase_Month = FORMAT(dim_customer[Customer_First_Purchase_Date],"MMM YYYY")
		lineageTag: f9bd7f8c-970b-4455-a7a4-9be256e252f1
		summarizeBy: none
		sortByColumn: Month_Sorting

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Customer_Lifetime_Month = DATEDIFF(STARTOFMONTH(dim_customer[Customer_First_Purchase_Date]),STARTOFMONTH(dim_customer[Customer_Last_Purchase_Date]),MONTH)
		formatString: 0
		lineageTag: 359fb47c-21c5-4f54-89c2-b9d423905fe6
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Month_Sorting = MONTH(dim_customer[Customer_First_Purchase_Date]) + YEAR(dim_customer[Customer_First_Purchase_Date])*100
		formatString: 0
		lineageTag: dc9c026e-51cb-4abd-a093-3da17abb559d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

