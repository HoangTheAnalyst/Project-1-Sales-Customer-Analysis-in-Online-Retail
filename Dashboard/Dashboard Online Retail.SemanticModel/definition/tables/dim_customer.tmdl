	column Customer_First_Purchase_Date = IF(LEFT(dim_customer[NCustomerID],6) = "GUEST_",BLANK(),CALCULATE(MIN(fact_sales[InvoiceDate]),ALLEXCEPT(dim_customer,dim_customer[NCustomerID])))
		formatString: General Date
		lineageTag: a57b523c-72c2-4e6a-a3eb-fec6bc0331a4
