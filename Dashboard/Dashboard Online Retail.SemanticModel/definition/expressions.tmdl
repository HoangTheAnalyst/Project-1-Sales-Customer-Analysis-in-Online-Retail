expression OnlineRetail =
		let
		    Source = #"Online Retail Root",
		    #"Removed Duplicates" = Table.Distinct(Source),
		    #"Capitalized Description" = Table.TransformColumns(#"Removed Duplicates",{{"Description", Text.Proper, type text}}),
		    #"Removed Unspecified Customers" = Table.SelectRows(#"Capitalized Description", each ([Country] <> "Unspecified")),
		    #"Replaced EIRE -> Ireland" = Table.ReplaceValue(#"Removed Unspecified Customers","EIRE","Ireland",Replacer.ReplaceText,{"Country"}),
		    #"Replaced RSA -> South Africa" = Table.ReplaceValue(#"Replaced EIRE -> Ireland","RSA","South Africa",Replacer.ReplaceText,{"Country"}),
		    #"Replaced USA -> United States" = Table.ReplaceValue(#"Replaced RSA -> South Africa","USA","United States",Replacer.ReplaceText,{"Country"}),
		    #"CustomerID -> Text" = Table.TransformColumnTypes(#"Replaced USA -> United States",{{"CustomerID", type text}}),
		    #"Replaced null(Customer ID) -> ""Guests""" = Table.ReplaceValue(#"CustomerID -> Text",null,"Guests/Unknown",Replacer.ReplaceValue,{"CustomerID"}),
		    #"Removed UnitPrice = 0" = Table.SelectRows(#"Replaced null(Customer ID) -> ""Guests""", each ([UnitPrice] <> 0)),
		    #"StockCode Start With a Number" = Table.AddColumn(#"Removed UnitPrice = 0", "Custom", each Value.Is(Value.FromText(Text.Start([StockCode], 1)), type number)),
		    #"Remove Any StockCode Without A Number Start" = Table.SelectRows(#"StockCode Start With a Number", each ([Custom] = true)),
		    #"Removed Checking Columns" = Table.RemoveColumns(#"Remove Any StockCode Without A Number Start",{"Custom"}),
		    #"Split ProductVariant from StockCode" = Table.SplitColumn(#"Removed Checking Columns", "StockCode", Splitter.SplitTextByRepeatedLengths(5), {"StockCode.1", "StockCode.2"}),
		    #"Renamed Columns" = Table.RenameColumns(#"Split ProductVariant from StockCode",{{"StockCode.1", "StockCode"}, {"StockCode.2", "ProductVariant"}}),
		    #"Uppercased Variant" = Table.TransformColumns(#"Renamed Columns",{{"ProductVariant", Text.Upper, type text}}),
		    #"Replace null ProductVariant with None" = Table.ReplaceValue(#"Uppercased Variant",null,"None",Replacer.ReplaceValue,{"ProductVariant"}),
		    #"Categorize Members ( Defined CustomerID ) or Guests" = Table.AddColumn(#"Replace null ProductVariant with None", "Custom", each if [CustomerID] = "Guests/Unknown" then "Guests/Unknown" else "Members"),
		    #"Renamed Columns1" = Table.RenameColumns(#"Categorize Members ( Defined CustomerID ) or Guests",{{"Custom", "TypeOfCustomers"}})
		in
