	column 'Total Months Active' = ```
			
			VAR First_Date = MINX(RELATEDTABLE(fact_sales),fact_sales[InvoiceDate])
			VAR Last_Date = MAX('fact_sales'[InvoiceDate])
			RETURN 
			DATEDIFF(First_Date,Last_Date,MONTH) + 1
			```
		formatString: 0
